# ============================================================
#  Environment configuration template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to source control.
# ============================================================

# ----------------------------------------------------------
# Application URLs
# ----------------------------------------------------------
BASE_URL=https://practicetestautomation.com
TODO_BASE_URL=https://demo.playwright.dev/todomvc
API_BASE_URL=https://jsonplaceholder.typicode.com

# ----------------------------------------------------------
# Authentication credentials (practice / demo sites only)
# ----------------------------------------------------------
TEST_USERNAME=student
TEST_PASSWORD=Password123

# ----------------------------------------------------------
# API configuration
# ----------------------------------------------------------
API_KEY=your_api_key_here
API_TIMEOUT_MS=10000

# ----------------------------------------------------------
# Test execution settings
# ----------------------------------------------------------
# Headless mode override (true | false)
HEADLESS=true

# Number of parallel workers (leave blank to use playwright default)
# WORKERS=4

# ----------------------------------------------------------
# Reporting
# ----------------------------------------------------------
ALLURE_RESULTS_DIR=allure-results
HTML_REPORT_DIR=playwright-report
